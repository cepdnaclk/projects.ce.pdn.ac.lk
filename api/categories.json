---
layout: null
permalink: "/api/categories/"
---
[
    {%- assign general_categories = site.html_pages | where: "parent", "Home" | where: "type", "GENERAL" -%}
    {%- assign course_categories = site.html_pages | where: "parent", "Home" | where: "type", "COURSE" -%}
    {%- assign children_list = general_categories | concat: course_categories -%}

    {% for category in children_list -%}
      {% include api_category.html category=category %}
      {% if forloop.last %}{% else %},{% endif %}
    {% endfor -%}
]
